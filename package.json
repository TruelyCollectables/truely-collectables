{
  "name": "truely-collectables",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "manual:pdf": "node scripts/build-manual-pdf.mjs",
    "simulate:instacomp-jobs": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/run-instacomp-job-simulations.mjs",
    "simulate:instacomp-accuracy": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/run-instacomp-accuracy-simulations.mjs",
    "simulate:lettertrack-evidence": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/run-lettertrack-evidence-simulations.mjs",
    "simulate:shipping": "node --import tsx scripts/run-shipping-simulations.ts",
    "simulate:shipping-purchase-audit": "node --import tsx scripts/run-shipping-purchase-audit-simulations.ts",
    "verify:instacomp": "npm run simulate:instacomp-jobs && npm run simulate:instacomp-accuracy",
    "verify:shipping": "npm run simulate:lettertrack-evidence && npm run simulate:shipping-purchase-audit && npm run simulate:shipping",
    "check:production-guardrails": "node scripts/check-production-guardrails.mjs",
    "status:production": "node scripts/deploy-production.mjs --quota-status",
    "preflight:production": "node scripts/deploy-production.mjs --preflight-only",
    "verify:production": "npm run lint && npm run verify:instacomp && npm run verify:shipping && npm run build && npm run check:production-guardrails && npm run preflight:production",
    "deploy:production": "node scripts/deploy-production.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "launch:production": "npm run verify:production && npm run deploy:production && npm run smoke:production",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "geist": "^1.7.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "stripe": "^22.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
