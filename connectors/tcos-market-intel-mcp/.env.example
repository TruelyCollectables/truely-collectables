# Server
PORT=8787
TCOS_CONNECTOR_TOKEN=replace-with-a-long-random-secret
TCOS_REQUIRE_PERSISTENCE=false
TCOS_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com

# Supabase persistence (service-role key must remain server-side)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public web discovery and exact-comp refresh
OPENAI_API_KEY=
TCOS_SEARCH_MODEL=gpt-5.6-terra
TCOS_SEARCH_MAX_RESULTS=20

# Optional marketplace-native discovery
EBAY_BROWSE_ACCESS_TOKEN=
X_BEARER_TOKEN=

# Profit defaults
TCOS_DEFAULT_SELLING_FEE_RATE=0.1325
TCOS_DEFAULT_ORDER_FEE=0.40
TCOS_DEFAULT_OUTBOUND_POSTAGE=0.78
TCOS_DEFAULT_SUPPLIES=0.25
TCOS_DEFAULT_RETURN_RESERVE_RATE=0.02
TCOS_DEFAULT_TARGET_ROI=0.10
